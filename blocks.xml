<?xml version="1.0" encoding="UTF-8"?>
<blocks>

    <block tag="mobile-gamecenter-id"
           code="subjectID"
           type="normal"
           returns="text"
           category="mobile"
           hidden="true"
           helpURL="event-mobile">
        <context>
            <requiredContext type="has" value="subjectID:String" />
        </context>
    </block>

    <block tag="event-mobile-gamecenter"
           type="event"
           returns="void"
           category="events"
           helpURL="event-mobile">
        <code>
            <event-def params="subjectID:String" innercode="#1" listener="addGameCenterListener(#0, ${eventRef});" />
        </code>
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@event.mobile.gamecenter.ready" code="300" />
                    <c text="@event.mobile.gamecenter.score" code="301" />
                    <c text="@event.mobile.gamecenter.achieve" code="302" />
                    <c text="@event.mobile.gamecenter.reset" code="303" />
                    <c text="@event.mobile.gamecenter.ready.fail" code="304" />
                    <c text="@event.mobile.gamecenter.score.fail" code="305" />
                    <c text="@event.mobile.gamecenter.achieve.fail" code="306" />
                    <c text="@event.mobile.gamecenter.reset.fail" code="307" />
                </choices>
            </dropdown>
            <code-block order="1" />
            <attached-block order="2" tag="mobile-gamecenter-id" />
        </fields>
        <context>
            <innerContext type="class" value="com.stencyl.behavior.Script" />
            <innerContext type="has" value="subjectID:String" />
        </context>
    </block>

    <block tag="gamecenter-init"
           code="com.stencyl.gamecenter.GameCenter.initialize();"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
    </block>

    <block tag="gamecenter-enabled"
           code="com.stencyl.gamecenter.GameCenter.isAuthenticated()"
           type="normal"
           returns="boolean"
           category="mobile"
           helpURL="game-mobile">
    </block>

    <block tag="gamecenter-id-name"
           code="com.stencyl.gamecenter.GameCenter.getPlayer~()"
           type="normal"
           returns="text"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@name" code="Name" />
                    <c text="@ID" code="ID" />
                </choices>
            </dropdown>
        </fields>
    </block>

    <block tag="gamecenter-board-submit"
           code="com.stencyl.gamecenter.GameCenter.reportScore(~, ~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <int order="0" />
            <text order="1" />
        </fields>
    </block>

    <block tag="gamecenter-board-show"
           code="com.stencyl.gamecenter.GameCenter.showLeaderboard(~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
        </fields>
    </block>

    <block tag="gamecenter-achievement-submit"
           code="com.stencyl.gamecenter.GameCenter.reportAchievement(~, ~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
            <number order="1" />
        </fields>
    </block>

    <block tag="gamecenter-achievement-show-reset"
           code="com.stencyl.gamecenter.GameCenter.~Achievements();"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <dropdown order="0">
                <choices>
                    <c text="@show" code="show" />
                    <c text="@reset" code="reset" />
                </choices>
            </dropdown>
        </fields>
    </block>

    <block tag="gamecenter-achievement-banner"
           code="com.stencyl.gamecenter.GameCenter.showAchievementBanner(~, ~);"
           type="action"
           returns="void"
           category="mobile"
           helpURL="game-mobile">
        <fields>
            <text order="0" />
            <text order="1" />
        </fields>
    </block>

</blocks>
